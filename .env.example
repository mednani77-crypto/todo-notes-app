# Required for server-side speech-to-text. Never expose this value through VITE_* variables.
OPENAI_API_KEY=

# Optional. Keep the default unless your OpenAI account supports a different transcription model.
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Optional server settings.
PORT=8787
MAX_AUDIO_BYTES=20971520
TRANSCRIPTION_TIMEOUT_MS=120000
